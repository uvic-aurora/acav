# Build directories (all build artifacts, compiled objects, Qt-generated
# files, CMake metadata, and test builds go here)
out/
build/
build-*/
release/
tmp_build/

# IDE and editor files
.idea/
.vscode/
*.swp
*.swo
*.user
*.pro.user
*.pro.user.*
*.qbs.user
*.qbs.user.*
.qmake.stash

# OS files
.DS_Store
Thumbs.db
.directory

# Temporary and cache files
*.tmp
*.temp
*.autosave
.cache/
.envrc

# LaTeX auxiliary files (for in-tree LaTeX sources under docs/)
*.aux
*.bbl
*.blg
*.out
*.toc
*.log
*.fls
*.fdb_latexmk

# Generated documentation
docs/html/
docs/latex/
docs/MEngReport/doc/main.outdir
docs/MEngReport/doc/main.pdf
docs/MEngReport/doc/main.ps

# Clang-generated precompiled modules (test outputs, regenerated by build)
*.pcm

# Generated compile database in examples (contains absolute paths)
docker/examples/compile_commands.json

# LaTeX build output for design presentation
docs/design/out/

# Development-only content (not for public release)
misc/
docs/feedback/
docs/presentation/
docs/worklog.md
docs/InternedString_JSON_Integration.md
docs/CLANG_DESIGN_PHILOSOPHY_AND_ASTVIEW_GUIDE.md
.dev/
