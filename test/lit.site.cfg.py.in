import os
import sys

# CMake will substitute these variables
config.acav_src_root = "@PROJECT_SOURCE_DIR@"
config.acav_obj_root = "@PROJECT_BINARY_DIR@"
config.acav_bin_dir = "@CMAKE_RUNTIME_OUTPUT_DIRECTORY@"
config.llvm_tools_dir = "@LLVM_TOOLS_BINARY_DIR@"
