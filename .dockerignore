# This file is part of ACAV.
# Docker build context exclusions
# Exclude all build directories to reduce context size

# Build directories (all patterns)
build/
build-*/
build-linux/
build-linux-release/
build-linux-debug/
build-release/
out/
.cache/

# Test directories (exclude everything except source files)
test/

# Unittests (not needed for runtime)
unittests/

# Git
.git/
.github/

# IDE/Editor
.vscode/
.idea/
*.swp
*.swo
*~

# Distribution output
dist/
*.tar
*.tar.gz
*.zip

# Temporary/Object files
*.o
*.a
*.so
*.dylib
*.pcm
*.ifc

# Misc (examples, tools, etc not needed)
misc/
examples/
!docker/examples/
todos/

# Documentation (not needed in runtime)
docs/
*.md
!docker/examples/README.md
.claude/
.cursor/
build/
build-debug
buld-fresh


# Test binaries
test_rusage_units
test_rusage_units.c
test_memory_profiling.cpp

# ignore data
data/

